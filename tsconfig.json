{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "app/runtime/messages.ts",
    "app/runtime/method-catalog.ts",
    "app/app/router.ts",
    "app/app/session.ts"
  ],
  "exclude": [
    "vendor",
    "wheels"
  ]
}